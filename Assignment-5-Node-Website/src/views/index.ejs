<%- include("partials/header") %>

<main>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Your next holiday starts here</p>
        <h1>Travel smarter with curated packages built for quick getaways.</h1>
        <p class="lead">
          Browse handpicked destinations, compare highlights, and book your trip in one simple form.
        </p>
        <a href="#packages" class="button">Explore Packages</a>
      </div>
      <div class="hero-visual">
        <img src="/images/hero-travel.jpg" alt="Tropical beach destination with turquoise water and palm-lined shore" />
        <div class="hero-visual-copy">
          <p class="eyebrow">Explore More</p>
          <h2>Beach sunsets, alpine views, and city lights in one place.</h2>
        </div>
      </div>
    </div>
  </section>

  <% if (bookingSuccess) { %>
    <section class="container notice success">
      <p>Your trip request has been saved successfully.</p>
    </section>
  <% } %>

  <section class="container section" id="packages">
    <div class="section-heading">
      <p class="eyebrow">Popular Packages</p>
      <h2>Choose a destination that fits your mood.</h2>
    </div>

    <div class="card-grid">
      <% destinations.forEach((destination) => { %>
        <article class="destination-card">
          <img src="<%= destination.image %>" alt="<%= destination.name %>" />
          <div class="card-body">
            <div class="meta">
              <span><%= destination.country %></span>
              <span><%= destination.duration %></span>
            </div>
            <h3><%= destination.name %></h3>
            <p><%= destination.summary %></p>
            <div class="card-footer">
              <strong><%= destination.price %></strong>
              <a href="/destinations/<%= destination.slug %>">View Details</a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="container section booking-section">
    <div class="section-heading">
      <p class="eyebrow">Book Your Trip</p>
      <h2>Send your request in a few seconds.</h2>
    </div>

    <form action="/book-trip" method="POST" class="booking-form">
      <input type="text" name="name" placeholder="Full Name" required />
      <input type="email" name="email" placeholder="Email Address" required />
      <select name="destination" required>
        <option value="">Select Destination</option>
        <% destinations.forEach((destination) => { %>
          <option value="<%= destination.name %>"><%= destination.name %></option>
        <% }) %>
      </select>
      <input type="number" name="travelers" min="1" max="10" value="1" />
      <input type="date" name="travelDate" required />
      <textarea name="notes" rows="4" placeholder="Special requests or preferences"></textarea>
      <button type="submit" class="button">Book Now</button>
    </form>
  </section>
</main>

<%- include("partials/footer") %>

