<%- include("partials/header") %>

<main class="container section">
  <div class="section-heading">
    <p class="eyebrow">Admin View</p>
    <h1>Recent Booking Requests</h1>
  </div>

  <% if (!bookings.length) { %>
    <div class="notice">
      <p>No bookings yet. Submit the homepage form to see entries here.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Destination</th>
            <th>Travelers</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach((booking) => { %>
            <tr>
              <td><%= booking.name %></td>
              <td><%= booking.email %></td>
              <td><%= booking.destination %></td>
              <td><%= booking.travelers %></td>
              <td><%= booking.travelDate %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<%- include("partials/footer") %>
