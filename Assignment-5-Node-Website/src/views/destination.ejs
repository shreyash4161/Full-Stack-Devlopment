<%- include("partials/header") %>

<main class="container section">
  <article class="detail-layout">
    <img src="<%= destination.image %>" alt="<%= destination.name %>" class="detail-image" />
    <div>
      <p class="eyebrow"><%= destination.country %></p>
      <h1><%= destination.name %></h1>
      <p class="lead"><%= destination.summary %></p>
      <p><%= destination.details %></p>
      <div class="detail-meta">
        <span><strong>Duration:</strong> <%= destination.duration %></span>
        <span><strong>Starting Price:</strong> <%= destination.price %></span>
      </div>
      <a href="/#packages" class="button">Back to Packages</a>
    </div>
  </article>
</main>

<%- include("partials/footer") %>
