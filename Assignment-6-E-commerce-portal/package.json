{
  "name": "resellr-marketplace",
  "version": "1.0.0",
  "description": "Premium resale marketplace built with React, Express, MongoDB, Socket.IO, and Tailwind CSS.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "npm run build:client",
    "build:client": "vite build --config client/vite.config.js",
    "preview:client": "vite preview --config client/vite.config.js",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "ecommerce",
    "marketplace",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-validator": "^7.3.2",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  }
}
